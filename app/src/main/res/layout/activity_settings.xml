<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootSettingsLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_home_background"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="18dp">

        <ImageButton
            android:id="@+id/btnBackSettings"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_burger_button"
            android:contentDescription="@string/back"
            android:padding="10dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="@null" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.16"
                android:text="@string/app_name"
                android:textColor="@color/gold_light"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.08"
                android:text="@string/settings_section"
                android:textColor="@color/text_tertiary"
                android:textSize="9sp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:background="@drawable/bg_home_chip"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:letterSpacing="0.08"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="@string/settings_system_chip"
            android:textColor="@color/gold_light"
            android:textSize="9sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="28dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="132dp"
                android:background="@drawable/bg_home_hero"
                android:elevation="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="18dp"
                android:paddingEnd="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_home_chip"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.1"
                        android:paddingStart="9dp"
                        android:paddingTop="4dp"
                        android:paddingEnd="9dp"
                        android:paddingBottom="4dp"
                        android:text="@string/settings_control_chip"
                        android:textColor="@color/gold_dark"
                        android:textSize="8sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="9dp"
                        android:fontFamily="sans-serif-black"
                        android:text="@string/settings_title"
                        android:textColor="@color/text_primary"
                        android:textSize="25sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:text="@string/settings_hero_subtitle"
                        android:textColor="@color/text_tertiary"
                        android:textSize="10sp" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:layout_marginBottom="10dp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.08"
                android:text="@string/settings_app_configuration"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_main_card"
                android:elevation="5dp"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    style="@style/ProfileFieldLabel"
                    android:text="@string/settings_theme_label" />

                <Spinner
                    android:id="@+id/spinnerTheme"
                    style="@style/SettingsSpinner" />

                <TextView
                    style="@style/ProfileFieldLabel"
                    android:layout_marginTop="15dp"
                    android:text="@string/settings_units_label" />

                <Spinner
                    android:id="@+id/spinnerUnits"
                    style="@style/SettingsSpinner" />

                <TextView
                    style="@style/ProfileFieldLabel"
                    android:layout_marginTop="15dp"
                    android:text="@string/settings_language_label" />

                <Spinner
                    android:id="@+id/spinnerLanguage"
                    style="@style/SettingsSpinner" />

                <TextView
                    style="@style/ProfileFieldLabel"
                    android:layout_marginTop="15dp"
                    android:text="@string/settings_text_size_label" />

                <Spinner
                    android:id="@+id/spinnerTextSize"
                    style="@style/SettingsSpinner" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:layout_marginBottom="10dp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.08"
                android:text="@string/settings_behavior_section"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_main_card"
                android:orientation="vertical"
                android:paddingStart="18dp"
                android:paddingTop="8dp"
                android:paddingEnd="12dp"
                android:paddingBottom="8dp">

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchAnimations"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:checked="true"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/settings_animations"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    app:thumbTint="@color/settings_switch_thumb"
                    app:trackTint="@color/settings_switch_track" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchKeepScreenOn"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:checked="true"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/settings_keep_screen_on"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    app:thumbTint="@color/settings_switch_thumb"
                    app:trackTint="@color/settings_switch_track" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchHistoryExpanded"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/settings_history_expanded"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    app:thumbTint="@color/settings_switch_thumb"
                    app:trackTint="@color/settings_switch_track" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchHaptics"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:checked="true"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/settings_haptics"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    app:thumbTint="@color/settings_switch_thumb"
                    app:trackTint="@color/settings_switch_track" />
            </LinearLayout>

            <TextView
                android:id="@+id/btnSaveSettings"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_training_primary_action"
                android:clickable="true"
                android:elevation="4dp"
                android:focusable="true"
                android:fontFamily="sans-serif-black"
                android:gravity="center"
                android:letterSpacing="0.08"
                android:text="@string/settings_save_action"
                android:textColor="@color/black"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
