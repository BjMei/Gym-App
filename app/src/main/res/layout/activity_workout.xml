<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/primary_dark"
    android:paddingTop="48dp"
    android:paddingBottom="32dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/gradient_header"
        android:padding="32dp"
        android:gravity="center"
        android:elevation="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="WORKOUT AUSWÄHLEN"
            android:textSize="36sp"
            android:textStyle="bold"
            android:textColor="@color/gold_primary"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.05" />
    </LinearLayout>

    <!-- ScrollView für Workout-Cards -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:padding="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_vertical">

            <!-- Push Card -->
            <LinearLayout
                android:id="@+id/pushCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/card_push"
                android:padding="28dp"
                android:gravity="center_vertical"
                android:minHeight="140dp"
                android:layout_marginBottom="24dp"
                android:elevation="8dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="PUSH DAY"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="0.05"
                    android:gravity="center"/>
            </LinearLayout>

            <!-- Pull Card -->
            <LinearLayout
                android:id="@+id/pullCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/card_pull"
                android:padding="28dp"
                android:gravity="center_vertical"
                android:minHeight="140dp"
                android:layout_marginBottom="24dp"
                android:elevation="8dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="PULL DAY"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="0.05"
                    android:gravity="center"/>
            </LinearLayout>

            <!-- Leg Card -->
            <LinearLayout
                android:id="@+id/legCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/card_leg"
                android:padding="28dp"
                android:gravity="center_vertical"
                android:minHeight="140dp"
                android:elevation="8dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="LEG DAY"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="0.05"
                    android:gravity="center"/>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

</LinearLayout>
