<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_home_metric"
    android:elevation="2dp"
    android:gravity="center_vertical"
    android:minHeight="112dp"
    android:orientation="horizontal"
    android:padding="15dp">

    <View
        android:layout_width="2dp"
        android:layout_height="42dp"
        android:background="@color/training_gold" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="13dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/kpiLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.1"
                android:text="LABEL"
                android:textColor="@color/text_tertiary"
                android:textSize="9sp" />

            <TextView
                android:id="@+id/kpiInfoButton"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_info_button"
                android:clickable="true"
                android:focusable="true"
                android:fontFamily="serif"
                android:gravity="center"
                android:includeFontPadding="false"
                android:text="i"
                android:textColor="@color/training_gold_highlight"
                android:textSize="13sp"
                android:textStyle="bold|italic"
                android:visibility="gone" />
        </LinearLayout>

        <TextView
            android:id="@+id/kpiValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="7dp"
            android:fontFamily="sans-serif-black"
            android:text="–"
            android:textColor="@color/training_gold_highlight"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/kpiTrend"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:fontFamily="sans-serif-medium"
            android:text="–"
            android:textColor="@color/text_tertiary"
            android:textSize="9sp" />
    </LinearLayout>
</LinearLayout>
