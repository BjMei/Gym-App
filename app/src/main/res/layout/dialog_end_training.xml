<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_surface"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvExitChip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_home_chip"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.1"
        android:paddingStart="10dp"
        android:paddingTop="5dp"
        android:paddingEnd="10dp"
        android:paddingBottom="5dp"
        android:text="@string/training_exit_chip"
        android:textColor="@color/gold_dark"
        android:textSize="8sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvExitTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:fontFamily="sans-serif-black"
        android:text="@string/training_exit_title"
        android:textColor="@color/text_primary"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvExitSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:lineSpacingExtra="2dp"
        android:text="@string/training_exit_message"
        android:textColor="@color/text_secondary"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/tvUnsavedWarning"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_dialog_secondary_action"
        android:padding="12dp"
        android:text="@string/training_exit_unsaved_warning"
        android:textColor="@color/training_gold_highlight"
        android:textSize="11sp"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/summarySection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvSummaryWorkoutType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.08"
            android:textColor="@color/training_gold_highlight"
            android:textSize="12sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_dialog_secondary_action"
            android:orientation="vertical"
            android:padding="14dp">

            <include layout="@layout/layout_training_summary_rows" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/confirmationActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnContinueTraining"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_dialog_secondary_action"
            android:backgroundTint="@null"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.04"
            android:text="@string/training_exit_continue"
            android:textColor="@color/text_primary"
            android:textSize="10sp"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/btnEndTraining"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_dialog_primary_action"
            android:backgroundTint="@null"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.04"
            android:text="@string/training_exit_end"
            android:textColor="#11100B"
            android:textSize="10sp"
            app:backgroundTint="@null" />
    </LinearLayout>

    <Button
        android:id="@+id/btnSummaryDone"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_dialog_primary_action"
        android:backgroundTint="@null"
        android:fontFamily="sans-serif-black"
        android:letterSpacing="0.06"
        android:text="@string/training_exit_to_split"
        android:textColor="#11100B"
        android:textSize="11sp"
        android:visibility="gone"
        app:backgroundTint="@null" />

</LinearLayout>
