<?xml version="1.0" encoding="utf-8"?>
<!--
    REDESIGN – activity_main.xml
    View-IDs identisch mit Original:
      workoutCard, statsCard
    Neu hinzugefügt (noch nicht in Java verdrahtet):
      fortschrittCard  → Codex: in MainActivity.java als Platzhalter ergänzen
    Keine Logik geändert.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootMainLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/primary_dark">

    <!-- ═══════════════════════════════════════
         HEADER
    ════════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="52dp"
        android:paddingBottom="28dp"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:background="@drawable/gradient_header"
        android:gravity="center_horizontal"
        android:elevation="12dp">

        <!-- Logo -->
        <ImageView
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:src="@drawable/ic_dumbbell"
            android:tint="@color/text_primary"
            android:layout_marginBottom="16dp"/>

        <!-- App-Titel -->
        <TextView
            android:id="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="IRONX"
            android:textSize="44sp"
            android:textStyle="bold"
            android:textColor="@color/gold_primary"
            android:letterSpacing="0.15"
            android:fontFamily="sans-serif-black"
            android:layout_marginBottom="6dp"/>

        <!-- Untertitel -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dein persönlicher Trainingsbegleiter"
            android:textSize="13sp"
            android:textColor="@color/text_tertiary"
            android:fontFamily="sans-serif"
            android:textStyle="italic"/>
    </LinearLayout>

    <!-- ═══════════════════════════════════════
         KARTEN
    ════════════════════════════════════════════ -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:paddingTop="20dp"
        android:paddingBottom="28dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ──────────────────────────────
                 WORKOUT STARTEN
                 ID: workoutCard  (unverändert)
            ─────────────────────────────────── -->
            <LinearLayout
                android:id="@+id/workoutCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_main_card"
                android:padding="20dp"
                android:gravity="center_vertical"
                android:minHeight="88dp"
                android:layout_marginBottom="14dp"
                android:elevation="6dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground">

                <!-- Icon-Kreis -->
                <LinearLayout
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:background="@drawable/bg_icon_circle"
                    android:gravity="center"
                    android:layout_marginEnd="20dp">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_workout_home"
                        android:tint="@color/gold_primary"/>
                </LinearLayout>

                <!-- Text -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="WORKOUT STARTEN"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="0.04"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Push · Pull · Legs"
                        android:textSize="12sp"
                        android:textColor="@color/text_tertiary"
                        android:fontFamily="sans-serif"/>
                </LinearLayout>

                <!-- Pfeil -->
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@android:drawable/arrow_up_float"
                    android:tint="#44FFD700"
                    android:rotation="90"/>
            </LinearLayout>

            <!-- ──────────────────────────────
                 STATISTIK
                 ID: statsCard  (unverändert)
            ─────────────────────────────────── -->
            <LinearLayout
                android:id="@+id/statsCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_main_card"
                android:padding="20dp"
                android:gravity="center_vertical"
                android:minHeight="88dp"
                android:layout_marginBottom="14dp"
                android:elevation="6dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:background="@drawable/bg_icon_circle"
                    android:gravity="center"
                    android:layout_marginEnd="20dp">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_stats_home"
                        android:tint="@color/gold_primary"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="STATISTIK"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="0.04"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Kennzahlen &amp; Auswertung"
                        android:textSize="12sp"
                        android:textColor="@color/text_tertiary"
                        android:fontFamily="sans-serif"/>
                </LinearLayout>

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@android:drawable/arrow_up_float"
                    android:tint="#44FFD700"
                    android:rotation="90"/>
            </LinearLayout>

            <!-- ──────────────────────────────
                 FORTSCHRITT
                 ID: fortschrittCard  (NEU – noch Platzhalter)
                 Codex: in MainActivity.java ergänzen:
                   LinearLayout fortschrittCard = findViewById(R.id.fortschrittCard);
                   fortschrittCard.setOnClickListener(v -> { /* später */ });
            ─────────────────────────────────── -->
            <LinearLayout
                android:id="@+id/fortschrittCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_main_card"
                android:padding="20dp"
                android:gravity="center_vertical"
                android:minHeight="88dp"
                android:layout_marginBottom="14dp"
                android:elevation="6dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:background="@drawable/bg_icon_circle"
                    android:gravity="center"
                    android:layout_marginEnd="20dp">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_progress_home"
                        android:tint="@color/gold_primary"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="FORTSCHRITT"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="0.04"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Trends, PRs &amp; Balance"
                        android:textSize="12sp"
                        android:textColor="@color/text_tertiary"
                        android:fontFamily="sans-serif"/>
                </LinearLayout>

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@android:drawable/arrow_up_float"
                    android:tint="#44FFD700"
                    android:rotation="90"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
