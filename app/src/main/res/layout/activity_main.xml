<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/primary_dark">

    <LinearLayout
        android:id="@+id/mainContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/primary_dark"
        android:paddingTop="12dp"
        android:paddingBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="start"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="8dp">

            <ImageButton
                android:id="@+id/btnOpenDrawer"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@android:color/transparent"
                android:src="@android:drawable/ic_menu_sort_by_size"
                app:tint="@color/gold_primary"
                android:contentDescription="@string/drawer_open" />
        </LinearLayout>

        <!-- ScrollView für Buttons -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="16dp"
            android:paddingBottom="20dp"
            android:paddingStart="28dp"
            android:paddingEnd="28dp"
            android:background="@drawable/gradient_header_plain"
            android:elevation="12dp">

            <ImageView
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:src="@drawable/ic_dumbbell"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="12dp"
                app:tint="@color/text_primary"
                android:contentDescription="@string/app_name" />

            <TextView
                android:id="@+id/title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textSize="34sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_gravity="center_horizontal"
                android:letterSpacing="0.15"
                android:fontFamily="sans-serif-black" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home_tagline"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="12dp"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true"
            android:padding="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_vertical">

                <!-- Workout Card -->
                <LinearLayout
                    android:id="@+id/workoutCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/card_workout"
                    android:padding="28dp"
                    android:gravity="center_vertical"
                    android:minHeight="140dp"
                    android:layout_marginBottom="24dp"
                    android:elevation="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?android:attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="74dp"
                        android:layout_height="74dp"
                        android:layout_marginEnd="22dp"
                        android:padding="16dp"
                        android:background="@drawable/icon_badge"
                        android:src="@drawable/ic_workout_home"
                        app:tint="@color/gold_primary"
                        android:contentDescription="@string/nav_workout" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/home_workout_title"
                            android:textSize="26sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            android:fontFamily="sans-serif-black"
                            android:letterSpacing="0.05" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/home_workout_subtitle"
                            android:textSize="13sp"
                            android:textColor="@color/text_tertiary"
                            android:layout_marginTop="6dp"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Statistik Card -->
                <LinearLayout
                    android:id="@+id/statsCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/card_stats"
                    android:padding="28dp"
                    android:gravity="center_vertical"
                    android:minHeight="140dp"
                    android:elevation="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?android:attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="74dp"
                        android:layout_height="74dp"
                        android:layout_marginEnd="22dp"
                        android:padding="16dp"
                        android:background="@drawable/icon_badge"
                        android:src="@drawable/ic_stats_home"
                        app:tint="@color/gold_primary"
                        android:contentDescription="@string/nav_stats" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/nav_stats"
                            android:textSize="26sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            android:fontFamily="sans-serif-black"
                            android:letterSpacing="0.05" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/home_stats_subtitle"
                            android:textSize="13sp"
                            android:textColor="@color/text_tertiary"
                            android:layout_marginTop="6dp"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Fortschritt Card -->
                <LinearLayout
                    android:id="@+id/progressCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/card_progress"
                    android:padding="28dp"
                    android:gravity="center_vertical"
                    android:minHeight="140dp"
                    android:layout_marginTop="24dp"
                    android:elevation="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?android:attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="74dp"
                        android:layout_height="74dp"
                        android:layout_marginEnd="22dp"
                        android:padding="16dp"
                        android:background="@drawable/icon_badge"
                        android:src="@drawable/ic_progress_home"
                        app:tint="@color/gold_primary"
                        android:contentDescription="@string/nav_progress" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/nav_progress"
                            android:textSize="26sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            android:fontFamily="sans-serif-black"
                            android:letterSpacing="0.05" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/home_progress_subtitle"
                            android:textSize="13sp"
                            android:textColor="@color/text_tertiary"
                            android:layout_marginTop="6dp"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/drawerPanel"
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/primary"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/nav_menu"
            android:textColor="@color/gold_primary"
            android:textStyle="bold"
            android:textSize="20sp"
            android:letterSpacing="0.08"
            android:paddingBottom="16dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider" />

        <TextView
            android:id="@+id/drawerWorkout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/nav_workout_emoji"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:paddingTop="18dp"
            android:paddingBottom="18dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/drawerHistory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/nav_history_emoji"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:paddingTop="18dp"
            android:paddingBottom="18dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/drawerStats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/nav_stats_emoji"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:paddingTop="18dp"
            android:paddingBottom="18dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/drawerProgress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/nav_progress_emoji"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:paddingTop="18dp"
            android:paddingBottom="18dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/drawerReset"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/nav_reset_emoji"
            android:textColor="@color/error"
            android:textSize="16sp"
            android:paddingTop="18dp"
            android:paddingBottom="18dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/drawerSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/nav_settings_emoji"
            android:textColor="@color/text_tertiary"
            android:textSize="16sp"
            android:paddingTop="18dp"
            android:paddingBottom="18dp"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>
