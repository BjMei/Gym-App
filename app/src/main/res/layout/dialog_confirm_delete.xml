<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_surface"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_home_chip"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.1"
        android:paddingStart="10dp"
        android:paddingTop="5dp"
        android:paddingEnd="10dp"
        android:paddingBottom="5dp"
        android:text="@string/dialog_security_chip"
        android:textColor="@color/gold_dark"
        android:textSize="8sp"
        android:textStyle="bold" />

    <FrameLayout
        android:layout_width="66dp"
        android:layout_height="66dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_circle_dark"
        android:padding="17dp">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@string/delete"
            android:src="@drawable/ic_ironx_delete"
            app:tint="@null" />
    </FrameLayout>

    <TextView
        android:id="@+id/tvDeleteTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="15dp"
        android:fontFamily="sans-serif-black"
        android:gravity="center"
        android:text="@string/delete_entry_title"
        android:textColor="@color/text_primary"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvDeleteMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="20dp"
        android:fontFamily="sans-serif"
        android:gravity="center"
        android:lineSpacingExtra="2dp"
        android:textColor="@color/text_secondary"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnDeleteCancel"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_dialog_secondary_action"
            android:backgroundTint="@null"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.06"
            android:text="@string/cancel"
            android:textAllCaps="false"
            android:textColor="@color/text_primary"
            android:textSize="11sp"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/btnDeleteConfirm"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_dialog_danger_action"
            android:backgroundTint="@null"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.06"
            android:text="@string/delete"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="11sp"
            app:backgroundTint="@null" />
    </LinearLayout>
</LinearLayout>
