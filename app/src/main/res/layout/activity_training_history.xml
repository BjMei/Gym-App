<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootHistoryLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/primary_dark">

    <TextView
        android:id="@+id/tvHistoryTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Trainingsverlauf"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:fontFamily="sans-serif-black"
        android:letterSpacing="0.05"
        android:paddingBottom="6dp" />

    <TextView
        android:id="@+id/tvHistorySubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="DEINE GESPEICHERTEN ÜBUNGEN"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="@color/text_secondary"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.12"
        android:paddingBottom="10dp" />

    <TextView
        android:id="@+id/tvEmptyState"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Noch keine Trainings gespeichert"
        android:textSize="16sp"
        android:textColor="@color/text_secondary"
        android:paddingTop="24dp"
        android:visibility="gone" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:paddingTop="16dp">

        <LinearLayout
            android:id="@+id/historyListContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </ScrollView>

</LinearLayout>


