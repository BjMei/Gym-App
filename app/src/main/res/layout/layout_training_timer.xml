<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="64dp"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    android:layout_marginBottom="14dp"
    android:background="@drawable/bg_stopwatch_card"
    android:elevation="4dp"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="18dp"
    android:paddingEnd="14dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="10dp"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.18"
        android:rotation="270"
        android:text="@string/training_timer"
        android:textColor="@color/text_tertiary"
        android:textSize="8sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvStopwatch"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:fontFamily="monospace"
        android:letterSpacing="0.03"
        android:text="00:00.00"
        android:textColor="@color/training_gold"
        android:textSize="26sp"
        android:textStyle="bold" />

    <ImageButton
        android:id="@+id/btnStartStop"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginEnd="8dp"
        android:background="@drawable/bg_training_primary_action"
        android:contentDescription="Start/Stop"
        android:padding="10dp"
        android:scaleType="centerInside"
        android:src="@drawable/ic_ironx_play"
        app:tint="@color/black" />

    <ImageButton
        android:id="@+id/btnReset"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_circle_dark"
        android:contentDescription="@string/training_reset"
        android:padding="10dp"
        android:scaleType="centerInside"
        android:src="@drawable/ic_ironx_reset"
        app:tint="@color/training_gold" />

</LinearLayout>
