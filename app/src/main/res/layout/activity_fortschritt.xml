<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/primary_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:background="@drawable/gradient_header">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📊 FORTSCHRITT"
            android:textColor="@color/gold_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.08" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PERFORMANCE ANALYTICS"
            android:textColor="@color/text_tertiary"
            android:textSize="10sp"
            android:letterSpacing="0.05" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/primary">

        <LinearLayout
            android:id="@+id/tabKraft"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="12dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📈 Kraft"
                android:textColor="@color/gold_primary"
                android:textSize="13sp"
                android:textStyle="bold" />

            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:layout_marginTop="6dp"
                android:background="@color/gold_primary" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/tabMuskeln"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="12dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💪 Muskeln"
                android:textColor="@color/text_tertiary"
                android:textSize="13sp"
                android:textStyle="bold" />

            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:layout_marginTop="6dp"
                android:background="@color/gold_primary"
                android:visibility="invisible" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/tabKonsistenz"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="12dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔥 Konsistenz"
                android:textColor="@color/text_tertiary"
                android:textSize="13sp"
                android:textStyle="bold" />

            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:layout_marginTop="6dp"
                android:background="@color/gold_primary"
                android:visibility="invisible" />
        </LinearLayout>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:id="@+id/sectionKraft"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <Spinner
                        android:id="@+id/spinnerFortschrittExercise"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/spinner_background"
                        android:paddingStart="12dp" />

                    <Spinner
                        android:id="@+id/spinnerRangeKraft"
                        android:layout_width="90dp"
                        android:layout_height="48dp"
                        android:background="@drawable/spinner_background"
                        android:paddingStart="8dp" />
                </LinearLayout>

                <TextView
                    style="@style/ChartSectionLabel"
                    android:text="GESCHÄTZTES 1RM" />

                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/chart1RM"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:layout_marginBottom="12dp" />

                <TextView
                    style="@style/ChartSectionLabel"
                    android:text="MAX GEWICHT" />

                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/chartMaxGewicht"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:layout_marginBottom="12dp" />

                <TextView
                    style="@style/ChartSectionLabel"
                    android:text="VOLUMEN" />

                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/chartVolumen"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:layout_marginBottom="12dp" />

                <TextView
                    style="@style/ChartSectionLabel"
                    android:text="Ø WIEDERHOLUNGEN" />

                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/chartWiederholungen"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:layout_marginBottom="12dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/sectionMuskeln"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <Spinner
                    android:id="@+id/spinnerRangeMuskeln"
                    android:layout_width="120dp"
                    android:layout_height="48dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/spinner_background"
                    android:paddingStart="8dp" />

                <TextView
                    style="@style/ChartSectionLabel"
                    android:text="VOLUMEN JE MUSKELGRUPPE" />

                <com.github.mikephil.charting.charts.BarChart
                    android:id="@+id/chartMuskelVolumen"
                    android:layout_width="match_parent"
                    android:layout_height="240dp"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="6dp">

                        <TextView
                            style="@style/ChartSectionLabel"
                            android:text="PUSH VS PULL" />

                        <com.github.mikephil.charting.charts.PieChart
                            android:id="@+id/chartPushPull"
                            android:layout_width="match_parent"
                            android:layout_height="200dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="6dp">

                        <TextView
                            style="@style/ChartSectionLabel"
                            android:text="OBER VS UNTERKÖRPER" />

                        <com.github.mikephil.charting.charts.PieChart
                            android:id="@+id/chartOberUnter"
                            android:layout_width="match_parent"
                            android:layout_height="200dp" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvDysbalance"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:padding="14dp"
                    android:background="@drawable/card_border_gold"
                    android:textColor="#F5A623"
                    android:textSize="13sp"
                    android:lineSpacingExtra="4dp"
                    android:visibility="gone" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/sectionKonsistenz"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <Spinner
                    android:id="@+id/spinnerRangeKonsistenz"
                    android:layout_width="120dp"
                    android:layout_height="48dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/spinner_background"
                    android:paddingStart="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:background="@drawable/card_border_gold">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🔥 STREAK"
                            android:textColor="@color/text_tertiary"
                            android:textSize="10sp"
                            android:letterSpacing="0.08" />

                        <TextView
                            android:id="@+id/tvStreak"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 Tage"
                            android:textColor="@color/gold_primary"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Aktuell"
                            android:textColor="@color/text_tertiary"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:background="@drawable/card_border_gold">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🏆 BESTE SERIE"
                            android:textColor="@color/text_tertiary"
                            android:textSize="10sp"
                            android:letterSpacing="0.08" />

                        <TextView
                            android:id="@+id/tvBestStreak"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 Tage"
                            android:textColor="@color/gold_secondary"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp" />

                        <TextView
                            android:id="@+id/tvBestStreakZeitraum"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="–"
                            android:textColor="@color/text_tertiary"
                            android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    style="@style/ChartSectionLabel"
                    android:text="TRAININGSFREIE TAGE JE WOCHE" />

                <com.github.mikephil.charting.charts.BarChart
                    android:id="@+id/chartFreieTage"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:layout_marginBottom="12dp" />

                <TextView
                    style="@style/ChartSectionLabel"
                    android:text="TRAININGSQUOTE" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp"
                    android:background="@drawable/card_border_gold">

                    <com.github.mikephil.charting.charts.PieChart
                        android:id="@+id/chartQuote"
                        android:layout_width="140dp"
                        android:layout_height="140dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:id="@+id/tvQuoteProzent"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0%"
                            android:textColor="@color/gold_primary"
                            android:textSize="40sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvQuoteStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="–"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
