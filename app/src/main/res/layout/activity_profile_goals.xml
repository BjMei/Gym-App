<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootProfileGoalsLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_home_background"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="18dp">

        <ImageButton
            android:id="@+id/btnBackProfileGoals"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_burger_button"
            android:contentDescription="@string/back"
            android:padding="10dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="@null" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.16"
                android:text="@string/app_name"
                android:textColor="@color/gold_light"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.08"
                android:text="@string/profile_section"
                android:textColor="@color/text_tertiary"
                android:textSize="9sp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:background="@drawable/bg_home_chip"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:letterSpacing="0.08"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="@string/goals_chip"
            android:textColor="@color/gold_light"
            android:textSize="9sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="28dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="132dp"
                android:background="@drawable/bg_home_hero"
                android:elevation="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="18dp"
                android:paddingEnd="18dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_home_chip"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.1"
                        android:paddingStart="9dp"
                        android:paddingTop="4dp"
                        android:paddingEnd="9dp"
                        android:paddingBottom="4dp"
                        android:text="@string/profile_focus_chip"
                        android:textColor="@color/gold_dark"
                        android:textSize="8sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="9dp"
                        android:fontFamily="sans-serif-black"
                        android:text="@string/settings_profile_goals"
                        android:textColor="@color/text_primary"
                        android:textSize="25sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:text="@string/profile_goals_hero_subtitle"
                        android:textColor="@color/text_tertiary"
                        android:textSize="10sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:layout_marginBottom="10dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    style="@style/ProfileSectionTitleInline"
                    android:text="@string/profile_personal_data" />

                <TextView
                    android:id="@+id/infoProfilePersonalData"
                    style="@style/InlineInfoButton" />
            </LinearLayout>

            <LinearLayout
                style="@style/ProfileCard">

                <TextView
                    style="@style/ProfileFieldLabel"
                    android:text="@string/profile_name_label" />

                <EditText
                    android:id="@+id/etProfileName"
                    style="@style/ProfileInput"
                    android:hint="@string/profile_name_hint"
                    android:imeOptions="actionNext"
                    android:inputType="textCapWords|textPersonName" />

                <TextView
                    style="@style/ProfileFieldLabel"
                    android:layout_marginTop="15dp"
                    android:text="@string/profile_birth_year_label" />

                <EditText
                    android:id="@+id/etProfileBirthYear"
                    style="@style/ProfileInput"
                    android:hint="@string/profile_birth_year_hint"
                    android:clickable="true"
                    android:cursorVisible="false"
                    android:focusable="false"
                    android:imeOptions="actionNext"
                    android:inputType="none" />

                <TextView
                    style="@style/ProfileFieldLabel"
                    android:layout_marginTop="15dp"
                    android:text="@string/profile_height_label" />

                <EditText
                    android:id="@+id/etProfileHeight"
                    style="@style/ProfileInput"
                    android:hint="@string/profile_height_hint"
                    android:imeOptions="actionNext"
                    android:inputType="number"
                    android:maxLength="3" />

                <TextView
                    style="@style/ProfileFieldLabel"
                    android:layout_marginTop="15dp"
                    android:text="@string/profile_weight_label" />

                <EditText
                    android:id="@+id/etProfileWeight"
                    style="@style/ProfileInput"
                    android:clickable="false"
                    android:cursorVisible="false"
                    android:focusable="false"
                    android:inputType="none" />

                <TextView
                    style="@style/ProfileFieldLabel"
                    android:layout_marginTop="15dp"
                    android:text="@string/profile_body_fat_label" />

                <EditText
                    android:id="@+id/etProfileBodyFat"
                    style="@style/ProfileInput"
                    android:hint="@string/profile_body_fat_hint"
                    android:clickable="false"
                    android:cursorVisible="false"
                    android:focusable="false"
                    android:imeOptions="actionNext"
                    android:inputType="none" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:layout_marginBottom="10dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    style="@style/ProfileSectionTitleInline"
                    android:text="@string/profile_body_fat_measurements" />
            </LinearLayout>

            <LinearLayout
                style="@style/ProfileCard">

                <TextView
                    style="@style/ProfileFieldLabel"
                    android:text="@string/profile_body_fat_measurement_label" />

                <EditText
                    android:id="@+id/etBodyFatMeasurement"
                    style="@style/ProfileInput"
                    android:hint="@string/profile_body_fat_measurement_hint"
                    android:imeOptions="actionNext"
                    android:inputType="numberDecimal" />

                <TextView
                    style="@style/ProfileFieldLabel"
                    android:layout_marginTop="15dp"
                    android:text="@string/profile_measurement_date_label" />

                <EditText
                    android:id="@+id/etBodyFatMeasurementDate"
                    style="@style/ProfileInput"
                    android:clickable="true"
                    android:cursorVisible="false"
                    android:focusable="false"
                    android:inputType="none" />

                <TextView
                    android:id="@+id/btnAddBodyFatMeasurement"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_training_primary_action"
                    android:clickable="true"
                    android:focusable="true"
                    android:fontFamily="sans-serif-black"
                    android:gravity="center"
                    android:letterSpacing="0.06"
                    android:text="@string/profile_body_fat_measurement_add"
                    android:textColor="@color/black"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btnToggleBodyFatMeasurements"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/bg_training_input_compact"
                    android:clickable="true"
                    android:focusable="true"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center_vertical"
                    android:letterSpacing="0.08"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:text="@string/profile_body_fat_history_label"
                    android:textColor="@color/training_gold_highlight"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/llBodyFatMeasurements"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:layout_marginBottom="10dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    style="@style/ProfileSectionTitleInline"
                    android:text="@string/profile_weight_measurements" />

                <TextView
                    android:id="@+id/infoProfileWeightMeasurements"
                    style="@style/InlineInfoButton" />
            </LinearLayout>

            <LinearLayout
                style="@style/ProfileCard">

                <TextView
                    style="@style/ProfileFieldLabel"
                    android:text="@string/profile_measurement_weight_label" />

                <EditText
                    android:id="@+id/etWeightMeasurement"
                    style="@style/ProfileInput"
                    android:imeOptions="actionNext"
                    android:inputType="numberDecimal" />

                <TextView
                    style="@style/ProfileFieldLabel"
                    android:layout_marginTop="15dp"
                    android:text="@string/profile_measurement_date_label" />

                <EditText
                    android:id="@+id/etWeightMeasurementDate"
                    style="@style/ProfileInput"
                    android:clickable="true"
                    android:cursorVisible="false"
                    android:focusable="false"
                    android:inputType="none" />

                <TextView
                    android:id="@+id/btnAddWeightMeasurement"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_training_primary_action"
                    android:clickable="true"
                    android:focusable="true"
                    android:fontFamily="sans-serif-black"
                    android:gravity="center"
                    android:letterSpacing="0.06"
                    android:text="@string/profile_measurement_add"
                    android:textColor="@color/black"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btnToggleWeightMeasurements"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/bg_training_input_compact"
                    android:clickable="true"
                    android:focusable="true"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center_vertical"
                    android:letterSpacing="0.08"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:text="@string/profile_measurement_history_label"
                    android:textColor="@color/training_gold_highlight"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/llWeightMeasurements"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:layout_marginBottom="10dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    style="@style/ProfileSectionTitleInline"
                    android:text="@string/profile_training_goal" />

                <TextView
                    android:id="@+id/infoProfileTrainingGoal"
                    style="@style/InlineInfoButton" />
            </LinearLayout>

            <LinearLayout
                style="@style/ProfileCard">

                <TextView
                    style="@style/ProfileFieldLabel"
                    android:text="@string/profile_primary_goal" />

                <Spinner
                    android:id="@+id/spinnerGoal"
                    style="@style/SettingsSpinner" />

                <TextView
                    style="@style/ProfileFieldLabel"
                    android:layout_marginTop="15dp"
                    android:text="@string/profile_target_weight_label" />

                <EditText
                    android:id="@+id/etTargetWeight"
                    style="@style/ProfileInput"
                    android:imeOptions="actionNext"
                    android:inputType="numberDecimal" />

                <TextView
                    style="@style/ProfileFieldLabel"
                    android:layout_marginTop="15dp"
                    android:text="@string/profile_target_date_label" />

                <EditText
                    android:id="@+id/etTargetDate"
                    style="@style/ProfileInput"
                    android:clickable="true"
                    android:cursorVisible="false"
                    android:focusable="false"
                    android:hint="@string/profile_target_date_hint"
                    android:inputType="none" />

                <TextView
                    style="@style/ProfileFieldLabel"
                    android:layout_marginTop="15dp"
                    android:text="@string/profile_weekly_training_goal_label" />

                <EditText
                    android:id="@+id/etTrainingGoalPerWeek"
                    style="@style/ProfileInput"
                    android:hint="@string/profile_weekly_training_goal_hint"
                    android:imeOptions="actionNext"
                    android:inputType="number"
                    android:maxLength="1" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:layout_marginBottom="10dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    style="@style/ProfileSectionTitleInline"
                    android:text="@string/profile_training_profile" />

                <TextView
                    android:id="@+id/infoProfileTrainingProfile"
                    style="@style/InlineInfoButton" />
            </LinearLayout>

            <LinearLayout
                style="@style/ProfileCard">

                <TextView
                    style="@style/ProfileFieldLabel"
                    android:text="@string/profile_activity_level_label" />

                <Spinner
                    android:id="@+id/spinnerActivityLevel"
                    style="@style/SettingsSpinner" />

                <TextView
                    style="@style/ProfileFieldLabel"
                    android:layout_marginTop="15dp"
                    android:text="@string/profile_experience_label" />

                <Spinner
                    android:id="@+id/spinnerExperience"
                    style="@style/SettingsSpinner" />

                <TextView
                    style="@style/ProfileFieldLabel"
                    android:layout_marginTop="15dp"
                    android:text="@string/profile_preferred_days_label" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnDayMonday"
                            style="@style/ProfileDayButton"
                            android:text="@string/day_monday_short" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnDayTuesday"
                            style="@style/ProfileDayButton"
                            android:text="@string/day_tuesday_short" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnDayWednesday"
                            style="@style/ProfileDayButton"
                            android:text="@string/day_wednesday_short" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnDayThursday"
                            style="@style/ProfileDayButton"
                            android:text="@string/day_thursday_short" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnDayFriday"
                            style="@style/ProfileDayButton"
                            android:text="@string/day_friday_short" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnDaySaturday"
                            style="@style/ProfileDayButton"
                            android:text="@string/day_saturday_short" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnDaySunday"
                            style="@style/ProfileDayButton"
                            android:text="@string/day_sunday_short" />
                    </LinearLayout>
                </HorizontalScrollView>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:layout_marginBottom="10dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    style="@style/ProfileSectionTitleInline"
                    android:text="@string/profile_performance_goals" />

                <TextView
                    android:id="@+id/infoProfilePerformanceGoals"
                    style="@style/InlineInfoButton" />
            </LinearLayout>

            <LinearLayout
                style="@style/ProfileCard">

                <TextView
                    style="@style/ProfileFieldLabel"
                    android:text="@string/profile_strength_goal_label" />

                <Spinner
                    android:id="@+id/spinnerStrengthGoalExercise"
                    style="@style/SettingsSpinner" />

                <EditText
                    android:id="@+id/etStrengthGoalTarget"
                    style="@style/ProfileInput"
                    android:layout_marginTop="10dp"
                    android:imeOptions="actionNext"
                    android:inputType="numberDecimal" />

                <TextView
                    android:id="@+id/btnAddStrengthGoal"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_training_primary_action"
                    android:clickable="true"
                    android:focusable="true"
                    android:fontFamily="sans-serif-black"
                    android:gravity="center"
                    android:letterSpacing="0.06"
                    android:text="@string/profile_strength_goal_add"
                    android:textColor="@color/black"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvLegacyStrengthGoal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_training_input_compact"
                    android:lineSpacingExtra="2dp"
                    android:padding="12dp"
                    android:textColor="@color/training_gold_highlight"
                    android:textSize="11sp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/btnToggleStrengthGoals"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/bg_training_input_compact"
                    android:clickable="true"
                    android:focusable="true"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center_vertical"
                    android:letterSpacing="0.08"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:text="@string/profile_strength_goal_history_label"
                    android:textColor="@color/training_gold_highlight"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/llStrengthGoals"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <TextView
                    style="@style/ProfileFieldLabel"
                    android:layout_marginTop="15dp"
                    android:text="@string/profile_volume_goal_label" />

                <EditText
                    android:id="@+id/etVolumeGoal"
                    style="@style/ProfileInput"
                    android:imeOptions="actionDone"
                    android:inputType="numberDecimal" />
            </LinearLayout>

            <TextView
                android:id="@+id/btnSaveProfileGoals"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_training_primary_action"
                android:clickable="true"
                android:elevation="4dp"
                android:focusable="true"
                android:fontFamily="sans-serif-black"
                android:gravity="center"
                android:letterSpacing="0.08"
                android:text="@string/profile_save"
                android:textColor="@color/black"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
