<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/rounded_card"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvManageTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="Verwalten"
        android:textColor="@color/text_primary"
        android:textSize="24sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-black"
        android:layout_marginBottom="16dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <EditText
            android:id="@+id/etNewItem"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginEnd="10dp"
            android:gravity="center_vertical|start"
            android:hint="Neuen Eintrag eingeben"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:background="@drawable/rounded_input"
            android:paddingStart="16dp"
            android:paddingEnd="16dp" />

        <ImageButton
            android:id="@+id/btnAddItem"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/rounded_input"
            android:src="@android:drawable/ic_input_add"
            android:tint="@color/gold_primary"
            android:contentDescription="Hinzufügen"
            android:padding="12dp" />
    </LinearLayout>

    <ScrollView
        android:id="@+id/svManageItems"
        android:layout_width="match_parent"
        android:layout_height="320dp"
        android:layout_marginBottom="16dp"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/llManageItems"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </ScrollView>

    <Button
        android:id="@+id/btnCloseManageDialog"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:text="Schließen"
        android:textAllCaps="false"
        android:textColor="@color/primary_dark"
        android:textStyle="bold"
        android:background="@drawable/rounded_button" />

</LinearLayout>
