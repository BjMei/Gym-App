<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/primary_dark"
    android:paddingTop="48dp"
    android:paddingBottom="32dp">

    <!-- Header mit Gradient -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="28dp"
        android:paddingBottom="36dp"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:background="@drawable/gradient_header"
        android:elevation="12dp">
        
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
            android:text="PUSH DAY"
            android:textSize="38sp"
        android:textStyle="bold"
            android:textColor="@color/gold_primary"
            android:layout_gravity="start"
            android:letterSpacing="0.1"
            android:fontFamily="sans-serif-black"/>
            
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Wenn du nicht schwitzt, war's Cardio"
            android:textSize="16sp"
            android:textColor="@color/text_secondary"
            android:layout_gravity="start"
            android:layout_marginTop="8dp"
            android:fontFamily="sans-serif-medium"/>
    </LinearLayout>

    <!-- ScrollView für Eingabefelder -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Eingabebereich Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/rounded_card"
                android:padding="20dp"
                android:layout_marginBottom="20dp"
                android:elevation="6dp">

                <!-- Spinner für Übung -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Übung auswählen"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"
                    android:fontFamily="sans-serif-medium"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="20dp">

                    <Spinner
                        android:id="@+id/spinnerExercise"
                        android:layout_width="0dp"
                        android:layout_height="60dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="12dp"
                        android:background="@drawable/spinner_background"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:textColor="@color/text_primary"/>

                    <ImageButton
                        android:id="@+id/btnExerciseSettings"
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:background="@drawable/rounded_input"
                        android:src="@android:drawable/ic_menu_preferences"
                        android:contentDescription="Einstellungen"
                        android:scaleType="centerInside"
                        android:padding="12dp"
                        android:tint="@color/gold_primary"/>
                </LinearLayout>

                <!-- Letztes Training Anzeige -->
                <LinearLayout
                    android:id="@+id/llLastWorkout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/rounded_card"
                    android:padding="16dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="16dp"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/tvLastWorkoutTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Letztes Training"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"
                        android:fontFamily="sans-serif-medium"/>

                    <TextView
                        android:id="@+id/tvLastWorkoutData"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif"/>
                </LinearLayout>

                <!-- Satz 1 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Satz 1"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp"
                    android:layout_marginTop="4dp"
                    android:fontFamily="sans-serif-medium"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                <EditText
                    android:id="@+id/etWeight1"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                        android:layout_weight="1"
                        android:hint="Gewicht (kg)"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"
                        android:background="@drawable/rounded_input"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:textSize="16sp"
                        android:layout_marginEnd="8dp"
                        android:inputType="numberDecimal"/>

                    <EditText
                        android:id="@+id/etReps1"
                        android:layout_width="0dp"
                        android:layout_height="60dp"
                        android:layout_weight="1"
                        android:hint="Wiederholungen"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"
                        android:background="@drawable/rounded_input"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:textSize="16sp"
                        android:inputType="number"/>
                </LinearLayout>

                <!-- Satz 2 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Satz 2"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp"
                    android:fontFamily="sans-serif-medium"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <EditText
                        android:id="@+id/etWeight2"
                        android:layout_width="0dp"
                        android:layout_height="60dp"
                        android:layout_weight="1"
                        android:hint="Gewicht (kg)"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"
                        android:background="@drawable/rounded_input"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:textSize="16sp"
                        android:layout_marginEnd="8dp"
                        android:inputType="numberDecimal"/>

                    <EditText
                        android:id="@+id/etReps2"
                        android:layout_width="0dp"
                        android:layout_height="60dp"
                        android:layout_weight="1"
                        android:hint="Wiederholungen"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"
                        android:background="@drawable/rounded_input"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:textSize="16sp"
                        android:inputType="number"/>
                </LinearLayout>

                <!-- Satz 3 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Satz 3"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp"
                    android:fontFamily="sans-serif-medium"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <EditText
                        android:id="@+id/etWeight3"
                        android:layout_width="0dp"
                        android:layout_height="60dp"
                        android:layout_weight="1"
                        android:hint="Gewicht (kg)"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"
                        android:background="@drawable/rounded_input"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:textSize="16sp"
                        android:layout_marginEnd="8dp"
                        android:inputType="numberDecimal"/>

                    <EditText
                        android:id="@+id/etReps3"
                        android:layout_width="0dp"
                        android:layout_height="60dp"
                        android:layout_weight="1"
                        android:hint="Wiederholungen"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"
                        android:background="@drawable/rounded_input"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:textSize="16sp"
                        android:inputType="number"/>
                </LinearLayout>

                <!-- Satz 4 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Satz 4"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp"
                    android:fontFamily="sans-serif-medium"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="20dp">

                    <EditText
                        android:id="@+id/etWeight4"
                        android:layout_width="0dp"
                        android:layout_height="60dp"
                        android:layout_weight="1"
                        android:hint="Gewicht (kg)"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"
                        android:background="@drawable/rounded_input"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:textSize="16sp"
                        android:layout_marginEnd="8dp"
                        android:inputType="numberDecimal"/>

                    <EditText
                        android:id="@+id/etReps4"
                        android:layout_width="0dp"
                        android:layout_height="60dp"
                        android:layout_weight="1"
                        android:hint="Wiederholungen"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"
                        android:background="@drawable/rounded_input"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:textSize="16sp"
                        android:inputType="number"/>
                </LinearLayout>

                <!-- Button zum Speichern -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ImageButton
                        android:id="@+id/btnSave"
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:background="@drawable/rounded_button"
                        android:src="@android:drawable/ic_menu_save"
                        android:contentDescription="Speichern"
                        android:scaleType="centerInside"
                        android:padding="12dp"
                        android:tint="@color/text_primary"
                        android:elevation="8dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Cardio-Bereich -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/rounded_card"
                android:padding="20dp"
                android:layout_marginBottom="20dp"
                android:elevation="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CARDIO"
                    android:textColor="@color/text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="0.05"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cardio-Übung auswählen"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"
                    android:fontFamily="sans-serif-medium"/>

                <Spinner
                    android:id="@+id/spinnerCardio"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/spinner_background"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textColor="@color/text_primary"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Zeit in Minuten"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"
                    android:fontFamily="sans-serif-medium"/>

                <EditText
                    android:id="@+id/etCardioMinutes"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:hint="Minuten"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:background="@drawable/rounded_input"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textSize="16sp"
                    android:layout_marginBottom="16dp"
                    android:inputType="number"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ImageButton
                        android:id="@+id/btnSaveCardio"
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:background="@drawable/rounded_button"
                        android:src="@android:drawable/ic_menu_save"
                        android:contentDescription="Speichern"
                        android:scaleType="centerInside"
                        android:padding="12dp"
                        android:tint="@color/text_primary"
                        android:elevation="8dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Button für gespeicherte Trainings -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp">

                <ImageButton
                    android:id="@+id/btnViewHistory"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:background="@drawable/button_gradient_header"
                    android:src="@android:drawable/ic_menu_view"
                    android:contentDescription="Gespeicherte Trainings anzeigen"
                    android:scaleType="centerInside"
                    android:padding="12dp"
                    android:tint="@color/text_primary"
                    android:elevation="6dp"/>
            </LinearLayout>

            <!-- Liste der gespeicherten Übungen -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GESPEICHERTE ÜBUNGEN"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.05"/>

            <LinearLayout
                android:id="@+id/llEntries"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
