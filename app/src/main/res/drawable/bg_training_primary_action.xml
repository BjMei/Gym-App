<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/training_gold_pressed" />
            <corners android:radius="14dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:startColor="@color/training_gold_highlight"
                android:centerColor="@color/training_gold"
                android:endColor="#B58A3A" />
            <corners android:radius="14dp" />
        </shape>
    </item>
</selector>
