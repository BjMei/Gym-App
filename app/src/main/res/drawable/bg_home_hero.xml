<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:startColor="#E8C050"
                android:centerColor="#6A4E0C"
                android:endColor="#D4A829" />
            <corners android:radius="24dp" />
        </shape>
    </item>
    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:startColor="#242424"
                android:centerColor="#121212"
                android:endColor="#080808" />
            <corners android:radius="23dp" />
        </shape>
    </item>
</layer-list>
