<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- stärkerer Schatten -->
    <path
        android:fillColor="@android:color/transparent"
        android:pathData="M5.4,7.5 L19.4,7.5 M8.4,7.5 L9.2,19.5 L15.6,19.5 L16.4,7.5"
        android:strokeColor="#55000000"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:strokeWidth="3.6" />

    <!-- dunkle Außenkante -->
    <path
        android:fillColor="@android:color/transparent"
        android:pathData="M5,7 L19,7 M8,7 L8.8,19 L15.2,19 L16,7"
        android:strokeColor="#7A2B2A"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:strokeWidth="3.4" />

    <!-- roter Metallic-Hauptkörper -->
    <path
        android:fillColor="@android:color/transparent"
        android:pathData="M5,7 L19,7 M8,7 L8.8,19 L15.2,19 L16,7"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:strokeWidth="2.2">

        <aapt:attr name="android:strokeColor">
            <gradient
                android:type="linear"
                android:startX="12"
                android:startY="6"
                android:endX="12"
                android:endY="19">
                <item android:offset="0.00" android:color="#F2C0BE" />
                <item android:offset="0.18" android:color="#E7A3A1" />
                <item android:offset="0.38" android:color="#C95F5D" />
                <item android:offset="0.58" android:color="#9F3D3B" />
                <item android:offset="0.78" android:color="#D97774" />
                <item android:offset="1.00" android:color="#6F2423" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Griff / Deckel oben metallic -->
    <path
        android:fillColor="@android:color/transparent"
        android:pathData="M9,4.5 L15,4.5 M10.5,4.5 L11,3.5 L13,3.5 L13.5,4.5"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:strokeWidth="1.9">

        <aapt:attr name="android:strokeColor">
            <gradient
                android:type="linear"
                android:startX="12"
                android:startY="3.5"
                android:endX="12"
                android:endY="5">
                <item android:offset="0.00" android:color="#F7D4D2" />
                <item android:offset="0.35" android:color="#E7A3A1" />
                <item android:offset="0.70" android:color="#C95F5D" />
                <item android:offset="1.00" android:color="#7A2B2A" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- innere Rippen dunkel -->
    <path
        android:fillColor="@android:color/transparent"
        android:pathData="M10.5,10 L10.8,16 M13.5,10 L13.2,16"
        android:strokeColor="#7A2B2A"
        android:strokeAlpha="0.55"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:strokeWidth="1.25" />

    <!-- innere Rippen heller Metallic-Kern -->
    <path
        android:fillColor="@android:color/transparent"
        android:pathData="M10.5,10 L10.8,16 M13.5,10 L13.2,16"
        android:strokeColor="#E7A3A1"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:strokeWidth="0.65" />

    <!-- helle Glanzkante auf dem Deckel -->
    <path
        android:fillColor="@android:color/transparent"
        android:pathData="M6.3,6.35 L17.7,6.35"
        android:strokeColor="#85FFFFFF"
        android:strokeLineCap="round"
        android:strokeWidth="0.75" />

    <!-- dezenter Glanz links am Körper -->
    <path
        android:fillColor="@android:color/transparent"
        android:pathData="M8.65,8.4 L9.15,17.2"
        android:strokeColor="#66FFFFFF"
        android:strokeLineCap="round"
        android:strokeWidth="0.55" />

    <!-- dunkle Innenkante unten -->
    <path
        android:fillColor="@android:color/transparent"
        android:pathData="M9.2,18.6 L14.8,18.6"
        android:strokeColor="#5A1E1D"
        android:strokeAlpha="0.45"
        android:strokeLineCap="round"
        android:strokeWidth="0.8" />

</vector>