<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:startColor="#D7AD35"
                android:centerColor="#5A430B"
                android:endColor="#A77D12" />
            <corners android:radius="22dp" />
        </shape>
    </item>
    <item
        android:bottom="1dp"
        android:left="1dp"
        android:right="1dp"
        android:top="1dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:startColor="#211D10"
                android:centerColor="#151515"
                android:endColor="#0B0B0B" />
            <corners android:radius="21dp" />
        </shape>
    </item>
</layer-list>
