<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="oval">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="@color/gradient_gold_dark_start"
                android:endColor="@color/gradient_gold_dark_end" />
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="@color/gradient_gold_start"
                android:centerColor="@color/gradient_gold_mid"
                android:endColor="@color/gradient_gold_end" />
        </shape>
    </item>
</selector>
