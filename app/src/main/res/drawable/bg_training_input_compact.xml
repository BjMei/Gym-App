<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#202020"
                android:endColor="#121212" />
            <corners android:radius="12dp" />
            <stroke
                android:width="1.5dp"
                android:color="@color/training_gold" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#191919"
                android:endColor="#101010" />
            <corners android:radius="12dp" />
            <stroke
                android:width="1dp"
                android:color="#403617" />
        </shape>
    </item>
</selector>
