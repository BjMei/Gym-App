<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="oval">
            <solid android:color="@color/training_gold_pressed" />
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <gradient
                android:angle="315"
                android:startColor="@color/training_gold_highlight"
                android:endColor="@color/training_gold" />
        </shape>
    </item>
</selector>
